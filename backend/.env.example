# ---- Database ----
# Option A (recommended for cloud/AWS RDS): a single connection string
# DATABASE_URL=mysql+pymysql://<username>:<password>@<your-rds-endpoint>.rds.amazonaws.com:3306/verdant_ai
# DB_SSL=true

# Option B (local dev): individual pieces (used only if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_mysql_password
DB_NAME=verdant_ai

# ---- LLM (ingredient safety analysis) ----
GROQ_API_KEY=your_groq_api_key

# ---- Auth ----
# Used to sign session cookies — set a long random value in production
SECRET_KEY=change_this_to_a_long_random_secret

# ---- CORS ----
# Comma-separated list of frontend origins allowed to send credentialed requests
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
